{
  "regions": ["sfo1"],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/v1/.well-known/oauth-protected-resource"
    },
    {
      "source": "/.well-known/oauth-authorization-server",
      "destination": "/api/v1/.well-known/oauth-authorization-server"
    },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  }
}
