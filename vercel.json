{
  "regions": ["sfo1"],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/.well-known/(.*)", "destination": "/api" },
    { "source": "/((?!api|\\.well-known).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  }
}
