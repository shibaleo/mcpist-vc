# Canonical app URL — used as `redirect_uri` for OAuth and any other place
# we need to refer to ourselves with a stable hostname. On Vercel you can
# leave this unset; VERCEL_PROJECT_PRODUCTION_URL is auto-injected and
# we fall back to the request host in local dev.
APP_URL=https://mcpist-vc.vercel.app

# DB (Neon HTTP-driver URL)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Credential encryption (must match the legacy Go server's CREDENTIAL_ENCRYPTION_KEY).
# 32 bytes base64-encoded — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# API key signing (Ed25519 seed, 32 bytes base64)
SERVER_JWT_SIGNING_KEY=

# Optional: Loki
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_API_KEY=

# Module OAuth client credentials (only the ones you've enabled)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
TRELLO_CLIENT_ID=
TRELLO_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=
