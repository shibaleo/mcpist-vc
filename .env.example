# Canonical app URL — used as the OAuth issuer and for /redirect_uri building.
# On Vercel leave unset; VERCEL_PROJECT_PRODUCTION_URL is auto-injected and
# we fall back to the request host in local dev.
APP_URL=https://mcpist-vc.vercel.app

# Clerk — only the owner (OWNER_EMAIL in src/lib/auth.ts) is allowed in.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Ed25519 seed (32 bytes base64). Used to sign authorization codes,
# refresh tokens, and access tokens. Rotate the key (re-deploy) to
# invalidate every issued token.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SERVER_JWT_SIGNING_KEY=

# PostgreSQL connection string for the postgresql MCP module. The MCP
# server runs queries against this DB on the owner's behalf. Standard
# libpq URL (sslmode=require auto-appended; localhost blocked).
MCPIST_DATABASE_URL=postgresql://user:pass@host:5432/db
